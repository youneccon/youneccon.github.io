---
/* タグライン見出し: 周期的にホワイトノイズへ溶けて再形成する。
   SVG feTurbulence + feDisplacementMap を SMIL で自走アニメ。
   サイズ/折り返しは clamp + max-width でブラウザ幅に連動。 */
interface Props {
  text: string;
  class?: string;
}
const { text, class: className = "" } = Astro.props;
const uid = "nz" + Math.random().toString(36).slice(2, 8);
---

<svg class="nz-defs" aria-hidden="true" width="0" height="0">
  <defs>
    <filter id={uid} x="-15%" y="-30%" width="130%" height="160%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.012 0.8" numOctaves="2" seed="7" result="noise">
        <animate
          attributeName="baseFrequency"
          dur="9s"
          repeatCount="indefinite"
          keyTimes="0;0.72;0.8;0.9;1"
          values="0.012 0.8; 0.012 0.8; 0.02 0.96; 0.012 0.8; 0.012 0.8"
        />
      </feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        xChannelSelector="R"
        yChannelSelector="G"
        scale="0"
      >
        <animate
          attributeName="scale"
          dur="9s"
          repeatCount="indefinite"
          calcMode="linear"
          keyTimes="0;0.7;0.76;0.82;0.9;1"
          values="0;0;46;18;0;0"
        />
      </feDisplacementMap>
    </filter>
  </defs>
</svg>

<h1 class={`nz ${className}`} style={`filter:url(#${uid})`}>{text}</h1>

<style>
  .nz {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 1.1rem + 5.2vw, 6rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    max-width: 16ch;
    text-wrap: balance;
  }
  .nz-defs {
    position: absolute;
    width: 0;
    height: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .nz {
      filter: none !important;
    }
  }
</style>
