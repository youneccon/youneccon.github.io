---
import Base from "../layouts/Base.astro";
import NoiseText from "../components/NoiseText.astro";
import KineticHeadline from "../components/KineticHeadline.tsx";
import { profile, about, skills, skillTags, works, nav } from "../data/site";

const flagship = works[0];
const otherWorks = works.slice(1);
const statusLabel: Record<string, string> = { live: "公開中", wip: "制作中", planned: "構想中" };
const TIER_LABEL: Record<string, string> = {
  presentation: "Presentation 層",
  application: "Application 層",
  data: "Data 層",
};
---

<Base title={`${profile.name} — Portfolio`}>
  <!-- ===== Header ===== -->
  <header class="hdr">
    <a class="hdr__brand" href="#top">{profile.name}</a>
    <nav class="hdr__nav">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <a href={profile.github} target="_blank" rel="noopener">GitHub ↗</a>
    </nav>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero" id="top">
    <div class="hero__top container">
      <p class="eyebrow reveal">{profile.role}</p>
    </div>
    <div class="hero__center container">
      <NoiseText text={profile.tagline} />
      <p class="hero__sub reveal">{profile.subline}</p>
    </div>
    <div class="hero__foot container">
      <a class="hero__scroll reveal" href="#work">Work をみる ↓</a>
    </div>
  </section>

  <!-- ===== Work (flagship case study) ===== -->
  <section class="section" id="work">
    <div class="container">
      <p class="eyebrow reveal">Selected Work</p>
      <h2 class="sec-title reveal-chars">{flagship.title}</h2>
      <p class="sec-lead reveal muted">{flagship.subtitle}</p>

      <div class="cs">
        <!-- sticky 三層ダイアグラム -->
        <aside class="cs__visual">
          <div class="stack" id="tierStack">
            <div class="tier" data-tier="presentation">
              <span class="tier__k">Presentation</span>
              <span class="tier__d">React SPA / 3D / 印刷ページ</span>
            </div>
            <div class="tier" data-tier="application">
              <span class="tier__k">Application</span>
              <span class="tier__d">FastAPI(async) / ドメイン層</span>
            </div>
            <div class="tier" data-tier="data">
              <span class="tier__k">Data</span>
              <span class="tier__d">PostgreSQL — 制約/トリガー/ビュー</span>
            </div>
          </div>
          <div class="cs__meta">
            <span>{flagship.year}</span><span>{flagship.role}</span>
          </div>
        </aside>

        <!-- スクロールで進む章 -->
        <div class="cs__chapters">
          {flagship.chapters?.map((c, i) => (
            <article class="chap reveal" data-chap={i} data-tier-focus={c.tier ?? ""}>
              <span class="chap__kicker">
                {c.kicker}
                {c.tier && <span class="chap__layer">{TIER_LABEL[c.tier]}</span>}
              </span>
              <h3 class="chap__h">{c.heading}</h3>
              <p class="chap__b">{c.body}</p>
            </article>
          ))}
          <div class="cs__links reveal">
            {flagship.liveUrl && <a class="btn" href={flagship.liveUrl} target="_blank" rel="noopener">▶ ライブデモを開く</a>}
          </div>
        </div>
      </div>

      <!-- その他の作品 -->
      <div class="cards">
        {otherWorks.map((w) => (
          <div class="card reveal">
            <div class="card__top">
              <span class={`badge badge--${w.status}`}>{statusLabel[w.status]}</span>
              <span class="card__year muted">{w.year}</span>
            </div>
            <h3 class="card__title">{w.title}</h3>
            <p class="card__sub muted">{w.subtitle}</p>
            <p class="card__sum">{w.summary}</p>
            <div class="card__stack">{w.stack.map((s) => <span>{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== About ===== -->
  <section class="section" id="about">
    <div class="container about">
      <div class="about__l">
        <p class="eyebrow reveal">About</p>
        <h2 class="sec-title reveal-chars">{about.lead}</h2>
      </div>
      <div class="about__r">
        {about.body.map((p) => <p class="reveal">{p}</p>)}
      </div>
    </div>
  </section>

  <!-- ===== Skills ===== -->
  <section class="section" id="skills">
    <div class="container">
      <p class="eyebrow reveal">Skills</p>
      <div class="skills">
        {skills.map((s, i) => (
          <div class="skill reveal" style={`--reveal-delay:${i * 80}ms`}>
            <h3 class="skill__t">{s.title}</h3>
            <p class="skill__d muted">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="tags reveal">
        {skillTags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- ===== Contact ===== -->
  <section class="section" id="contact">
    <div class="container contact">
      <p class="eyebrow reveal">Contact</p>
      <h2 class="contact__h reveal">
        <KineticHeadline text="話してみませんか。" stagger={0.04} />
      </h2>
      <div class="contact__links reveal">
        <a class="contact__a" href={`mailto:${profile.email}`}>{profile.email}</a>
        <a class="contact__a" href={profile.github} target="_blank" rel="noopener">GitHub</a>
        {profile.x && <a class="contact__a" href={profile.x} target="_blank" rel="noopener">X</a>}
      </div>
    </div>
  </section>

  <footer class="ftr">
    <span class="muted">© 2026 {profile.name}</span>
    <span class="muted">Built with Astro · three.js</span>
  </footer>
</Base>

<style>
  /* ---- header ---- */
  .hdr {
    position: fixed; inset: 0 0 auto 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem var(--gutter);
  }
  .hdr__brand { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.02em; }
  .hdr__nav { display: flex; gap: 1.4rem; font-size: var(--step--1); }
  .hdr__nav a { color: var(--text); opacity: 0.8; transition: opacity 0.3s; }
  .hdr__nav a:hover { opacity: 1; }
  @media (max-width: 640px) { .hdr__nav { display: none; } }

  /* ---- hero ---- */
  .hero { position: relative; min-height: 100svh; overflow: hidden; display: flex; align-items: center; }
  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  /* オーバーレイは pointer-events: none で、マウスを背後の鯉(canvas)へ通す */
  .hero__top { position: absolute; top: 14vh; left: 0; right: 0; z-index: 2; pointer-events: none; }
  .hero__center { position: relative; z-index: 1; width: 100%; pointer-events: none; }
  .hero__sub { font-size: var(--step-1); max-width: 30ch; margin-top: 1.5rem; }
  .hero__foot { position: absolute; bottom: 7vh; left: 0; right: 0; z-index: 2; }
  .hero__scroll {
    font-family: var(--font-display); font-size: var(--step--1);
    letter-spacing: 0.15em; color: var(--muted); white-space: nowrap; pointer-events: auto;
  }
  .hero__scroll:hover { color: var(--accent); }

  /* ---- section titles ---- */
  .sec-title { font-size: var(--step-3); margin: 0.6rem 0 0.4rem; max-width: 22ch; text-wrap: balance; }
  .sec-lead { font-size: var(--step-1); margin-bottom: 3.5rem; }

  /* ---- case study (sticky scroll) ---- */
  .cs { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 6vw, 6rem); margin-top: 2rem; }
  @media (max-width: 860px) { .cs { grid-template-columns: 1fr; } }
  .cs__visual { position: sticky; top: 18vh; align-self: start; height: fit-content; }
  @media (max-width: 860px) { .cs__visual { position: relative; top: 0; margin-bottom: 2rem; } }
  .stack { display: flex; flex-direction: column; gap: 10px; }
  .tier {
    border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.1rem 1.3rem; background: var(--bg-elev);
    display: flex; flex-direction: column; gap: 2px;
    transition: border-color 0.5s var(--ease), background 0.5s var(--ease), transform 0.5s var(--ease);
  }
  .tier__k { font-family: var(--font-display); font-size: var(--step-0); }
  .tier__d { font-size: var(--step--1); color: var(--muted); }
  .tier.is-focus {
    border-color: var(--accent);
    background: linear-gradient(var(--accent-dim), var(--accent-dim)), var(--bg-elev);
    transform: translateX(6px);
  }
  .cs__meta { display: flex; justify-content: space-between; margin-top: 1.2rem; font-size: var(--step--1); color: var(--muted); }

  .cs__chapters { display: flex; flex-direction: column; gap: clamp(3rem, 9vh, 7rem); padding-block: 6vh; }
  .chap__kicker { font-family: var(--font-display); font-size: var(--step--1); letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); display: inline-flex; align-items: center; }
  .chap__layer {
    margin-left: 0.8rem; padding: 2px 9px; border-radius: 999px;
    border: 1px solid var(--accent); color: var(--accent);
    font-size: 0.64rem; letter-spacing: 0.06em; text-transform: none;
  }
  .chap__h { font-size: var(--step-2); margin: 0.5rem 0 0.7rem; text-wrap: balance; }
  .chap__b { color: var(--muted); max-width: 44ch; }
  .cs__links { display: flex; gap: 1.6rem; align-items: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fbf7ef;
    padding: 0.7rem 1.25rem; border-radius: 999px;
    font-family: var(--font-display); font-size: var(--step--1); letter-spacing: 0.04em;
    transition: transform 0.3s var(--ease), background 0.3s;
  }
  .btn:hover { transform: translateY(-2px); background: #855239; }

  /* ---- other work cards ---- */
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-top: clamp(4rem, 10vh, 8rem); }
  @media (max-width: 640px) { .cards { grid-template-columns: 1fr; } }
  .card { border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem; background: var(--bg-elev); transition: border-color 0.4s; }
  .card:hover { border-color: var(--accent); }
  .card__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .badge { font-size: 0.7rem; letter-spacing: 0.1em; padding: 3px 9px; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); }
  .badge--live { color: var(--accent); border-color: var(--accent); }
  .card__title { font-size: var(--step-1); }
  .card__sub { font-size: var(--step--1); margin: 2px 0 0.8rem; }
  .card__sum { font-size: var(--step-0); margin-bottom: 1rem; }
  .card__stack { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .card__stack span { font-size: 0.72rem; color: var(--muted); border: 1px solid var(--line-soft); padding: 2px 8px; border-radius: 6px; }

  /* ---- about ---- */
  .about { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(2rem, 6vw, 6rem); }
  @media (max-width: 760px) { .about { grid-template-columns: 1fr; } }
  .about__r p { margin-bottom: 1.4rem; }

  /* ---- skills ---- */
  .skills { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-bottom: 3rem; }
  @media (max-width: 640px) { .skills { grid-template-columns: 1fr; } }
  .skill { border-top: 1px solid var(--line); padding-top: 1.1rem; }
  .skill__t { font-size: var(--step-1); margin-bottom: 0.4rem; }
  .skill__d { font-size: var(--step-0); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .tag { font-size: var(--step--1); color: var(--muted); border: 1px solid var(--line); padding: 4px 12px; border-radius: 999px; }

  /* ---- contact ---- */
  .contact { text-align: center; }
  .contact__h { font-size: var(--step-4); margin: 0.5rem 0 2rem; }
  .contact__links { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; }
  .contact__a { font-family: var(--font-display); font-size: var(--step-1); border-bottom: 1px solid var(--line); padding-bottom: 3px; transition: border-color 0.3s, color 0.3s; }
  .contact__a:hover { color: var(--accent); border-color: var(--accent); }

  /* ---- footer ---- */
  .ftr { display: flex; justify-content: space-between; padding: 2rem var(--gutter); border-top: 1px solid var(--line-soft); font-size: var(--step--1); }
</style>

<script>
  // ケーススタディ: 章が画面に入ったら、対応する層をハイライト
  function syncTiers() {
    const stack = document.getElementById("tierStack");
    if (!stack) return;
    const tiers = stack.querySelectorAll<HTMLElement>(".tier");
    const chaps = document.querySelectorAll<HTMLElement>(".chap");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const focus = (e.target as HTMLElement).dataset.tierFocus;
          tiers.forEach((t) =>
            t.classList.toggle("is-focus", !!focus && t.dataset.tier === focus)
          );
        });
      },
      { threshold: 0.6 }
    );
    chaps.forEach((c) => io.observe(c));
  }
  syncTiers();
  document.addEventListener("astro:page-load", syncTiers);
</script>
